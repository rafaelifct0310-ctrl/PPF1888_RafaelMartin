<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sale_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Informe de ventas</h2>

                        <div class="row mt32 mb32">
                            <div class="col-4">
                                <strong>Desde:</strong> <span t-field="doc.date_from"/>
                            </div>
                            <div class="col-4">
                                <strong>Hasta:</strong> <span t-field="doc.date_to"/>
                            </div>
                            <div class="col-4">
                                <strong>Cliente:</strong> <span t-esc="doc.partner_id.name or 'Todos'"/>
                            </div>
                        </div>

                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Pedido</th>
                                    <th>Fecha</th>
                                    <th>Cliente</th>
                                    <th>Producto</th>
                                    <th class="text-end">Cantidad</th>
                                    <th class="text-end">Precio Unitario</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.get_report_lines()" t-as="line">
                                    <tr>
                                        <td><span t-esc="line['pedido']"/></td>
                                        <td><span t-esc="line['fecha']"/></td>
                                        <td><span t-esc="line['cliente']"/></td>
                                        <td><span t-esc="line['producto']"/></td>
                                        <td class="text-end"><span t-esc="line['cantidad']"/></td>
                                        <td class="text-end"><span t-esc="line['precio_unitario']"/></td>
                                        <td class="text-end"><span t-esc="line['subtotal']"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row justify-content-end">
                            <div class="col-4 text-end">
                                <p><strong>Total General: </strong> <span t-esc="doc.get_total_general()"/></p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>