<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sale_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Informe de ventas</h2>

                    <p><strong>Fecha desde:</strong>
                        <span t-esc="data.get('date_from') or 'Sin filtro'"/>
                    </p>
                    <p><strong>Fecha hasta:</strong>
                        <span t-esc="data.get('date_to') or 'Sin filtro'"/>
                    </p>
                    <p><strong>Cliente:</strong>
                        <span t-esc="data.get('partner_name') or 'Todos'"/>
                    </p>

                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Pedido</th>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th>Producto</th>
                                <th>Cantidad</th>
                                <th>Precio Unitario</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="data.get('lines', [])" t-as="line">
                                <tr>
                                    <td><span t-esc="line['pedido']"/></td>
                                    <td><span t-esc="line['fecha']"/></td>
                                    <td><span t-esc="line['cliente']"/></td>
                                    <td><span t-esc="line['producto']"/></td>
                                    <td><span t-esc="line['cantidad']"/></td>
                                    <td><span t-esc="line['precio_unitario']"/></td>
                                    <td><span t-esc="line['subtotal']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <p>
                        <strong>Total general:</strong>
                        <span t-esc="data.get('total', 0.0)"/>
                    </p>
                </div>
            </t>
        </t>
    </template>
</odoo>