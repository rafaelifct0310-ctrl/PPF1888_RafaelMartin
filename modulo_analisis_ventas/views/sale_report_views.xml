<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sale_report_wizard_form" model="ir.ui.view">
        <field name="name">sale.report.wizard.form</field>
        <field name="model">sale.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Informe de ventas">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button 
                        name="action_print_report" 
                        string="Imprimir PDF" 
                        type="object" 
                        class="btn-primary"/>
                    <button 
                        string="Cancelar" 
                        special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_sale_report_wizard" model="ir.actions.act_window">
        <field name="name">Analisis de ventas</field>
        <field name="res_model">sale.report.wizard</field>
        <field name="view_mode">form</field>

        <field name="target">new</field>

    </record>

    <menuitem 
        id="menu_sale_report_root" 
        name="Analisis de ventas"
        parent="sale.sale_order_menu"
        action="action_sale_report_wizard"
        sequence="90" />


</odoo>